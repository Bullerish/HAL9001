# HAL9001 environment — copy this to /etc/hal9001/hal.env on the server,
# fill in REAL values, then: chmod 600 /etc/hal9001/hal.env
#
# NEVER commit the real file. This .example (placeholders only) is the only one in git.

# Required — the LLM key the hive thinks with (this is what burns tokens).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Required — the shared hive store (identity, events, journal, race records, donations).
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=REPLACE_ME

# Optional — ambient pace. "slow" (~6x slower) keeps a 24/7 box cheap. 1 = snappy demo pace.
HAL_PACE=slow

# Optional but IMPORTANT for a headless box — turn on AUTONOMOUS mode (the hive self-drives: matmul
# race, self-set goals, gap-filling, journaling). Without this the box only acts on visitor requests,
# the "matrices being worked" panel goes stale, and self-set goals stay stuck at "Proposed". There is
# no console on the box, so this env is the only way to enable it there. on/off (default: leave as-is).
HAL_AUTONOMOUS=on

# Optional — how this node reports itself in the dashboard's LIVE node count. "core" = part of the
# hal9001.io hive box; "volunteer" = remote donated compute. Defaults to "core" (leave unset on the box).
HAL_NODE_ROLE=core

# Optional — IDLE SELF-DRIVING (autonomous mode). How many HELPER nodes the hive keeps alive so the
# swarm stays a mesh that can cross-query continuously. DEFAULT 0 (OFF) — auto-spawn is opt-in until you
# confirm hired workers actually JOIN the mesh on this host (on the self-contained box they were seen to
# spawn but not peer up, causing the root to re-hire every ~60s). Set to 1-2 once verified. Ceiling 5.
HAL_TARGET_NODES=0
# Optional — how often (seconds) the idle mesh runs a cross-node competition (the nodes querying each
# other). Default 300 (~5 min). The DAILY BUDGET is the real cost throttle; this only paces the cadence.
HAL_CROSSQUERY_SECS=300

# Optional — turn ON the donations endpoint (/api/donate). Leave UNSET to keep it disabled (404).
# Set a long random string; your Stripe webhook sends it in the X-HAL-Secret header.
# Generate one with:  openssl rand -hex 32
HAL_DONATE_SECRET=

# Daily FREE LLM allowance HAL may spend on YOUR Anthropic key with nobody paying. 0 = HAL never spends
# your usage on its own — no autonomous self-driving, no free visitor asks — it only thinks once a
# payment/donation ('fund' action) tops up today's budget. The free CPU work (matmul/tensor search at
# small sizes, wall-clock benchmarks) keeps running either way (it costs no Anthropic tokens). Set this
# above 0 only if you WANT to grant a free daily self-improvement allowance out of your own pocket.
HAL_DAILY_USD=0
# Token prices in USD per 1,000,000 tokens — SET THESE to match your model's current rate (they drift).
# Defaults are a Haiku-class ballpark; check Anthropic's pricing for your model.
HAL_PRICE_IN=1.0
HAL_PRICE_OUT=5.0

# Optional — number of FREE tokens each new visitor gets on first load (defaults to 0 — none).
# Visitors get nothing for free by default; set this >0 only to deliberately offer a free trial.
HAL_FREE_TOKENS=0

# ── Stripe token purchases (bite 24) ──────────────────────────────────────────────────────────────
# Both /api/checkout and /api/stripe-webhook stay OFF (404) until these are set.
# 1) Your Stripe secret/restricted key. The restricted key needs "Checkout Sessions: write".
#    rk_live_... for real money, rk_test_... for test mode. NEVER commit this.
STRIPE_SECRET_KEY=
# 2) The signing secret of the webhook endpoint you create in the Stripe dashboard, pointed at
#    https://hal9001.io/api/stripe-webhook and subscribed to "checkout.session.completed".
#    Stripe shows it as whsec_...  — this is what verifies that callbacks really came from Stripe.
STRIPE_WEBHOOK_SECRET=
# Optional — public base URL used for Stripe success/cancel redirects (defaults to https://hal9001.io).
HAL_PUBLIC_URL=https://hal9001.io

